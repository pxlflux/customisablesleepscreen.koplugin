msgstr "Tekst (donker)"

msgid "Icon set"
msgstr "Icoonset"

msgid "Choose from different icon styles."
msgstr "Kies uit verschillende icoonsstijlen."

msgid "Icon size"
msgstr "Icoongrootte"

msgid "Size of section icons."
msgstr "Grootte van sectie-iconen."

msgid "Progress bar height"
msgstr "Hoogte voortgangsbalk"

msgid "Thickness of the horizontal progress bars shown in each section."
msgstr "Dikte van de horizontale voortgangsbalken weergegeven in elke sectie."

msgid "Show icons"
msgstr "Iconen tonen"

msgid "Display decorative icons at the start of each section."
msgstr "Toont decoratieve iconen aan het begin van elke sectie."

msgid "Show progress bars"
msgstr "Voortgangsbalken tonen"

msgid "Display horizontal progress bars showing completion percentage."
msgstr "Toont horizontale voortgangsbalken met het voltooiingspercentage."

msgid "Show decorative bar on message section"
msgstr "Decoratiebalk weergeven in berichtsectie"

msgid "Displays a purely decorative progress bar under the message section, matching the message section colour and the progress bars in other sections."
msgstr "Toont een puur decoratieve voortgangsbalk onder de berichtensectie, passend bij de kleur van de berichtensectie en de voortgangsbalken in andere secties."

msgid "Title font face"
msgstr "Lettertype titel"

msgid "Choose the font face for the main heading text in each section"
msgstr "Kies het lettertype voor de hoofdkopregel in elke sectie"

msgid "Title font size"
msgstr "Tekengrootte titel"

msgid "Choose the font size for the main heading text in each section"
msgstr "Kies de tekengrootte voor de hoofdkopregel in elke sectie"

msgid "Subtitle font face"
msgstr "Lettertype ondertitel"

msgid "Choose the font face for the information below the main heading text."
msgstr "Kies het lettertype voor de informatie onder de hoofdkopregel."

msgid "Subtitle font size"
msgstr "Tekengrootte ondertitel"

msgid "Choose the font size for the information below the main heading text."
msgstr "Kies de tekengrootte voor de informatie onder de hoofdkopregel."

msgid "Text alignment"
msgstr "Tekstuitlijning"

msgid "Horizontal alignment of all text within sections."
msgstr "Horizontale uitlijning van alle tekst binnen secties."

msgid "Left"
msgstr "Links"

msgid "Right"
msgstr "Rechts"

msgid "Book multiline titles"
msgstr "Meerdere regels voor boektitels"

msgid "If deselected book titles will be truncated to a single line with an ellipsis"
msgstr "Als uitgeschakeld worden boektitels afgekapt tot één regel met een beletselteken"

msgid "Chapter multiline titles"
msgstr "Meerdere regels voor hoofdstuktitels"

msgid "If deselected chapter titles will be truncated to a single line with an ellipsis"
msgstr "Als uitgeschakeld worden hoofdstuktitels afgekapt tot één regel met een beletselteken"

msgid "Clean chapter titles"
msgstr "Hoofdstuktitels opschonen"

msgid "Removes structural prefixes like 'Chapter 5:' or 'Part II' from chapter titles and normalises capitalisation. Only works correctly with English chapter titles - disable for non-English books."
msgstr "Verwijdert structurele voorvoegsels zoals 'Hoofdstuk 5:' of 'Deel II' uit hoofdstuktitels en normaliseert het gebruik van hoofdletters. Werkt alleen correct met Engelstalige hoofdstuktitels — uitschakelen voor niet-Engelstalige boeken."

msgid "Make book title bold"
msgstr "Boektitel vetgedrukt maken"

msgid "Display the book title in bold font weight for extra emphasis."
msgstr "Toont de boektitel vetgedrukt voor extra nadruk."

msgid "No background"
msgstr "Geen achtergrond"

msgid "Book cover"
msgstr "Boekomslag"

msgid "Solid colour"
msgstr "Effen kleur"

msgid "Random image from folder"
msgstr "Willekeurige afbeelding uit map"

msgid "Stretch book cover to fill"
msgstr "Boekomslag uitrekken om te vullen"

msgid "When disabled, book cover will be scaled to fit within the screen while preserving aspect ratio."
msgstr "Wanneer uitgeschakeld wordt het boekomslag geschaald om op het scherm te passen met behoud van beeldverhouding."

msgid "Cover fill colour"
msgstr "Vulkleur omslag"

msgid "Background colour for non-stretched covers."
msgstr "Achtergrondkleur voor niet-uitgestrekte omslagen."

msgid "Pick cover fill colour"
msgstr "Vulkleur omslag kiezen"

msgid "Cover alignment"
msgstr "Uitlijning omslag"

msgid "Horizontal alignment of the cover image when not stretched."
msgstr "Horizontale uitlijning van de omslagafbeelding wanneer niet uitgerekt."

msgid "Solid background colour"
msgstr "Effen achtergrondkleur"

msgid "Pick background colour"
msgstr "Achtergrondkleur kiezen"

msgid "Background folder path"
msgstr "Pad naar achtergrondmap"

msgid "No images found in the selected folder. No background will be shown."
msgstr "Geen afbeeldingen gevonden in de geselecteerde map. Er wordt geen achtergrond weergegeven."

msgid "Background type"
msgstr "Achtergrondtype"

msgid "Background overlay"
msgstr "Achtergrondoverlay"

msgid "Add a colour layer over the background to reduce contrast."
msgstr "Voegt een kleurlaag over de achtergrond toe om het contrast te verminderen."
