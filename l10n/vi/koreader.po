msgstr "Các giá trị sẽ được khôi phục từ: %s"

msgid "Reset"
msgstr "Đặt lại"

msgid "Cancel"
msgstr "Hủy"

msgid "Save"
msgstr "Lưu"

msgid "Delete all custom presets"
msgstr "Xóa tất cả cấu hình tùy chỉnh"

msgid "Permanently removes all custom presets you've created. The built-in 'Default' preset will remain. This cannot be undone."
msgstr "Xóa vĩnh viễn tất cả cấu hình tùy chỉnh bạn đã tạo. Cấu hình tích hợp 'Mặc định' sẽ vẫn còn. Thao tác này không thể hoàn tác."

msgid "Are you sure you want to delete all custom presets? (built-in presets will remain)"
msgstr "Bạn có chắc muốn xóa tất cả cấu hình tùy chỉnh không? (Các cấu hình tích hợp sẽ vẫn còn)"

msgid "All custom presets deleted. Built-in presets remain."
msgstr "Đã xóa tất cả cấu hình tùy chỉnh. Các cấu hình tích hợp vẫn còn."

msgid "Sleep screen orientation"
msgstr "Hướng màn hình chờ"

msgid "Force the sleep screen to display in a specific orientation, regardless of how the device is held."
msgstr "Buộc màn hình chờ hiển thị theo hướng cụ thể, bất kể thiết bị được cầm theo chiều nào."

msgid "Auto (follow device)"
msgstr "Tự động (theo thiết bị)"

msgid "Use whatever orientation the device is currently in."
msgstr "Dùng hướng hiện tại của thiết bị."

msgid "Force portrait"
msgstr "Buộc dọc"

msgid "Always display the sleep screen in portrait mode."
msgstr "Luôn hiển thị màn hình chờ theo chiều dọc."

msgid "Force landscape"
msgstr "Buộc ngang"

msgid "Always display the sleep screen in landscape mode."
msgstr "Luôn hiển thị màn hình chờ theo chiều ngang."

msgid "Force upside-down portrait"
msgstr "Buộc dọc ngược"

msgid "Always display the sleep screen in inverted portrait mode."
msgstr "Luôn hiển thị màn hình chờ theo chiều dọc ngược."

msgid "Force upside-down landscape"
msgstr "Buộc ngang ngược"

msgid "Always display the sleep screen in inverted landscape mode."
msgstr "Luôn hiển thị màn hình chờ theo chiều ngang ngược."

msgid "Battery time calculation"
msgstr "Tính thời gian pin"

msgid "Method used to estimate remaining battery life."
msgstr "Phương pháp ước tính thời gian pin còn lại."

msgid "Since last charge"
msgstr "Kể từ lần sạc cuối"

msgid "Uses combined awake and sleeping battery drain since last charge"
msgstr "Dùng mức tiêu hao pin kết hợp khi hoạt động và ngủ kể từ lần sạc cuối"

msgid "Awake since last charge"
msgstr "Thời gian hoạt động kể từ lần sạc cuối"

msgid "Uses only active reading battery drain (more conservative estimate)"
msgstr "Chỉ dùng mức tiêu hao pin khi đọc sách (ước tính thận trọng hơn)"

msgid "Sleeping since last charge"
msgstr "Thời gian ngủ kể từ lần sạc cuối"

msgid "Uses only sleep mode battery drain"
msgstr "Chỉ dùng mức tiêu hao pin ở chế độ ngủ"

msgid "Manual calculation"
msgstr "Tính thủ công"

msgid "Use a custom battery drain rate (1-10% per hour)"
msgstr "Dùng tốc độ tiêu hao pin tùy chỉnh (1–10%/giờ)"

msgid "Set manual drain rate"
msgstr "Đặt tốc độ tiêu hao thủ công"

msgid "Battery drain rate (% per hour)"
msgstr "Tốc độ tiêu hao pin (%/giờ)"

msgid "Typical devices drain 1-5% per hour while reading"
msgstr "Thiết bị thông thường tiêu hao 1–5%/giờ khi đọc sách"

msgid "Daily statistics scope"
msgstr "Phạm vi thống kê hàng ngày"

msgid "Controls whether today's reading time and page count applies to the current book only, or all books read today. Note: reading streak and weekly goal achievement always reflect all books regardless of this setting."
msgstr "Kiểm soát xem thời gian đọc và số trang hôm nay áp dụng chỉ cho sách hiện tại hay tất cả sách đã đọc hôm nay. Lưu ý: chuỗi đọc sách và hoàn thành mục tiêu hàng tuần luôn phản ánh tất cả sách bất kể cài đặt này."

msgid "All books"
msgstr "Tất cả sách"

msgid "Today's reading time and page count across all books read today"
msgstr "Thời gian đọc và số trang hôm nay cho tất cả sách đã đọc hôm nay"

msgid "Current book only"
msgstr "Chỉ sách hiện tại"

msgid "Today's reading time and page count for the current book only"
msgstr "Thời gian đọc và số trang hôm nay chỉ cho sách hiện tại"

msgid "Show in file manager (outside of book)"
msgstr "Hiển thị trong trình quản lý tệp (ngoài sách)"

msgid "When enabled, the customisable sleep screen will display in file manager using the last saved book data."
msgstr "Khi bật, màn hình chờ tùy chỉnh sẽ hiển thị trong trình quản lý tệp bằng dữ liệu sách đã lưu gần nhất."

msgid "Hide built-in presets (except Default)"
msgstr "Ẩn cấu hình tích hợp (trừ Mặc định)"

msgid "Hide the built-in presets from the preset list, keeping only the Default preset and your custom presets visible."
msgstr "Ẩn các cấu hình tích hợp khỏi danh sách, chỉ hiển thị cấu hình Mặc định và các cấu hình tùy chỉnh của bạn."

msgid "Setting saved. Preset list will update when you reopen this menu."
msgstr "Đã lưu cài đặt. Danh sách cấu hình sẽ cập nhật khi bạn mở lại menu này."

msgid "Presets"
msgstr "Cấu hình"

msgid "Save, load, and manage presets."
msgstr "Lưu, tải và quản lý các cấu hình."

msgid "Display modes"
msgstr "Chế độ hiển thị"

msgid "Global appearance settings."
msgstr "Cài đặt giao diện toàn cục."

msgid "Contents"
msgstr "Nội dung"

msgid "Control which sections appear and what information they display."
msgstr "Kiểm soát các phần hiển thị và thông tin chúng hiện thị."

msgid "Layout & Spacing"
msgstr "Bố cục & Khoảng cách"

msgid "Adjust the spatial settings of the information box."
msgstr "Điều chỉnh cài đặt không gian của hộp thông tin."

msgid "Colours, Icons & Bars"
msgstr "Màu sắc, Biểu tượng & Thanh"

msgid "Customise section colours, icon appearance, and progress bar styling."
msgstr "Tùy chỉnh màu sắc phần, giao diện biểu tượng và kiểu thanh tiến trình."

msgid "Fonts & Text"
msgstr "Phông chữ & Văn bản"

msgid "Configure text appearance."
msgstr "Cấu hình giao diện văn bản."

msgid "Background"
msgstr "Nền"

msgid "Choose what appears behind the information box."
msgstr "Chọn nội dung hiển thị phía sau hộp thông tin."

msgid "Advanced"
msgstr "Nâng cao"

msgid "Advanced configuration options."
msgstr "Tùy chọn cấu hình nâng cao."

msgid "About"
msgstr "Giới thiệu"

