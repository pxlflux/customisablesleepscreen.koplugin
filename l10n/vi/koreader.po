msgstr "Đặt lại"

msgid "Save"
msgstr "Lưu"

msgid "None"
msgstr "Không có"

msgid "Active preset: "
msgstr "Cấu hình đang dùng: "

msgid "Save current settings as new preset"
msgstr "Lưu cài đặt hiện tại làm cấu hình mới"

#, lua-format
msgid "What would you like to do with preset '%s'?"
msgstr "Bạn muốn làm gì với cấu hình '%s'?"

msgid "Update"
msgstr "Cập nhật"

#, lua-format
msgid "Are you sure you want to overwrite preset '%s' with current settings?"
msgstr "Bạn có chắc muốn ghi đè cấu hình '%s' bằng cài đặt hiện tại không?"

#, lua-format
msgid "Preset '%s' was updated with current settings"
msgstr "Cấu hình '%s' đã được cập nhật bằng cài đặt hiện tại"

#, lua-format
msgid "Are you sure you want to delete preset '%s'?"
msgstr "Bạn có chắc muốn xóa cấu hình '%s' không?"

msgid "Rename"
msgstr "Đổi tên"

msgid "Enter new preset name"
msgstr "Nhập tên cấu hình mới"

msgid "[ Built-in Presets ]"
msgstr "[ Cấu hình tích hợp ]"

msgid "[ Your Custom Presets ]"
msgstr "[ Cấu hình tùy chỉnh của bạn ]"

msgid "Book info"
msgstr "Thông tin sách"

msgid "Chapter info"
msgstr "Thông tin chương"

msgid "Daily info"
msgstr "Thông tin hàng ngày"

msgid "Device info"
msgstr "Thông tin thiết bị"

msgid "Custom message"
msgstr "Tin nhắn tùy chỉnh"

msgid "Reorder sections"
msgstr "Sắp xếp lại các phần"

msgid "Section order"
msgstr "Thứ tự phần"

msgid "At least one section must remain visible."
msgstr "Ít nhất một phần phải hiển thị."

msgid "Show book author"
msgstr "Hiển thị tác giả sách"

msgid "Display the author name below the book title."
msgstr "Hiển thị tên tác giả bên dưới tiêu đề sách."

msgid "Show book pages (pg x of x)"
msgstr "Hiển thị số trang sách (tr. x / x)"

msgid "Display total page count for the entire book."
msgstr "Hiển thị tổng số trang của toàn bộ cuốn sách."

msgid "Show book time remaining"
msgstr "Hiển thị thời gian đọc còn lại"

msgid ""
"Estimated reading time left to finish the book, based on your average "
"reading speed."
msgstr ""
"Thời gian đọc ước tính còn lại để hoàn thành cuốn sách, "
"dựa trên tốc độ đọc trung bình của bạn."

msgid "Show chapter count (ch x of x)"
msgstr "Hiển thị số chương (ch. x / x)"

msgid ""
"Display current chapter number and total chapters (e.g., 'Chapter 5 of 12')."
msgstr ""
"Hiển thị số chương hiện tại và tổng số chương (ví dụ: 'Chương 5 / 12')."

msgid "Show chapter pages (pg x of x)"
msgstr "Hiển thị số trang chương (tr. x / x)"

msgid "Display the number of pages in the current chapter."
msgstr "Hiển thị số trang trong chương hiện tại."

msgid "Show chapter time remaining"
msgstr "Hiển thị thời gian còn lại của chương"

msgid ""
"Estimated time to finish the current chapter, based on your reading speed."
msgstr ""
"Thời gian ước tính để hoàn thành chương hiện tại, dựa trên tốc độ đọc của bạn."

msgid "Daily page goal"
msgstr "Mục tiêu trang hàng ngày"

msgid ""
"Set how many pages you aim to read each day. Progress shown in the goal "
"section."
msgstr ""
"Đặt số trang bạn muốn đọc mỗi ngày. Tiến độ hiển thị trong phần mục tiêu."

msgid "Show current reading streak"
msgstr "Hiển thị chuỗi đọc sách hiện tại"

msgid "Display consecutive days you've met your reading goal."
msgstr "Hiển thị số ngày liên tiếp bạn đạt mục tiêu đọc sách."

msgid "Show weekly goal achievement"
msgstr "Hiển thị thành tích mục tiêu hàng tuần"

msgid "Number of days this week you've met your daily reading goal."
msgstr "Số ngày trong tuần này bạn đã đạt mục tiêu đọc sách hàng ngày."

msgid "Show pages read out of daily goal"
msgstr "Hiển thị số trang đã đọc so với mục tiêu ngày"

msgid ""
"Display pages read today compared to your daily target (e.g. '35/50 pages')."
msgstr ""
"Hiển thị số trang đã đọc hôm nay so với mục tiêu ngày (ví dụ: '35/50 trang')."

msgid "Show current time/date on separate line"
msgstr "Hiển thị giờ/ngày hiện tại trên dòng riêng"

msgid ""
"Display time/date on its own line below battery percentage instead of inline."
msgstr ""
"Hiển thị giờ/ngày trên dòng riêng bên dưới phần trăm pin thay vì hiển thị cùng dòng."

msgid "Enable 'Show battery time remaining' to use this option"
msgstr "Bật 'Hiển thị thời gian pin còn lại' để sử dụng tùy chọn này"

msgid "Show date instead of time"
msgstr "Hiển thị ngày thay vì giờ"

msgid ""
"Display current date (e.g. '29th Jan') instead of time in battery section"
msgstr ""
"Hiển thị ngày hiện tại (ví dụ: '29 tháng 1') thay vì giờ trong phần pin"

msgid "Show battery consumption rate"
msgstr "Hiển thị tốc độ tiêu hao pin"

msgid ""
"Display battery drain percentage per hour based on recent usage or manual "
"input (see advanced menu)"
msgstr ""
"Hiển thị phần trăm tiêu hao pin mỗi giờ dựa trên mức sử dụng gần đây "
"hoặc nhập thủ công (xem menu nâng cao)"

msgid "Show battery time remaining"
msgstr "Hiển thị thời gian pin còn lại"

msgid ""
"Estimated hours and minutes until battery is depleted, based on current "
"drain rate."
msgstr ""
"Số giờ và phút ước tính cho đến khi hết pin, dựa trên tốc độ tiêu hao hiện tại."

msgid "Use a separate custom message just for Customisable Sleep Screen"
msgstr "Dùng tin nhắn tùy chỉnh riêng chỉ cho màn hình chờ tùy chỉnh"

msgid "Book highlights"
msgstr "Đánh dấu trong sách"

msgid "Show a random highlight from the current book"
msgstr "Hiển thị một đánh dấu ngẫu nhiên từ cuốn sách hiện tại"

msgid "KOReader sleep message"
msgstr "Tin nhắn màn hình chờ KOReader"

msgid ""
"Uses KOReaders own sleep screen message function. Enable 'Add custom message "
"to sleep screen' to use this (Settings → Screen → Sleep screen → Sleep "
"screen message)."
msgstr ""
"Sử dụng chức năng tin nhắn màn hình chờ riêng của KOReader. "
"Bật 'Thêm tin nhắn tùy chỉnh vào màn hình chờ' để sử dụng "
"(Cài đặt → Màn hình → Màn hình chờ → Tin nhắn màn hình chờ)."

msgid "Message header"
msgstr "Tiêu đề tin nhắn"

msgid ""
"Custom header text displayed above the message. Supports variables: %d, %y, "
"%t, %b, %r."
msgstr ""
"Văn bản tiêu đề tùy chỉnh hiển thị phía trên tin nhắn. "
"Hỗ trợ biến: %d, %y, %t, %b, %r."

msgid "Change custom message header"
msgstr "Thay đổi tiêu đề tin nhắn tùy chỉnh"

msgid "Edit custom message"
msgstr "Chỉnh sửa tin nhắn tùy chỉnh"

msgid ""
"Write your custom message text. Only active when 'Custom message' is "
"selected. Supports variables: %d, %y, %t, %b, %r."
msgstr ""
"Nhập văn bản tin nhắn tùy chỉnh. Chỉ hoạt động khi chọn 'Tin nhắn tùy chỉnh'. "
"Hỗ trợ biến: %d, %y, %t, %b, %r."

msgid "Custom Customisable Sleep Screen message"
msgstr "Tin nhắn tùy chỉnh màn hình chờ tùy chỉnh"

msgid "Book highlight maximum length"
msgstr "Độ dài tối đa đánh dấu sách"

msgid "Maximum characters to display for highlights (0 = no limit)."
msgstr "Số ký tự tối đa để hiển thị đánh dấu (0 = không giới hạn)."

msgid "Maximum highlight length"
msgstr "Độ dài đánh dấu tối đa"

msgid "Set to 0 for no limit"
msgstr "Đặt thành 0 để không giới hạn"

msgid "Add quotation marks to highlights"
msgstr "Thêm dấu ngoặc kép vào đánh dấu"

msgid ""
"Wraps all highlights in curly double quotes, removing any pre-existing "
"quotation marks."
msgstr ""
"Bọc tất cả đánh dấu trong dấu ngoặc kép cong, xóa bỏ các dấu ngoặc kép có sẵn."

msgid "Show highlight location"
msgstr "Hiển thị vị trí đánh dấu"

msgid ""
"Display the chapter title and page number where the highlight is found, "
"shown below the highlight text."
msgstr ""
"Hiển thị tiêu đề chương và số trang nơi đánh dấu được tìm thấy, "
"hiển thị bên dưới văn bản đánh dấu."

msgid "Show titles (top line)"
msgstr "Hiển thị tiêu đề (dòng trên)"

msgid ""
"Display the main heading text in each section. At least one of titles or "
"subtitles must be visible."
msgstr ""
"Hiển thị văn bản tiêu đề chính trong mỗi phần. Ít nhất một trong tiêu đề "
"hoặc phụ đề phải hiển thị."

msgid "Cannot hide both titles and subtitles. At least one must be visible."
msgstr "Không thể ẩn cả tiêu đề và phụ đề. Ít nhất một cái phải hiển thị."

msgid "Show subtitles (bottom lines)"
msgstr "Hiển thị phụ đề (dòng dưới)"

msgid ""
"Display information below main heading text in each section. At least one of "
"titles or subtitles must be visible."
msgstr ""
"Hiển thị thông tin bên dưới văn bản tiêu đề chính trong mỗi phần. "
"Ít nhất một trong tiêu đề hoặc phụ đề phải hiển thị."

msgid "Displayed sections"
msgstr "Các phần hiển thị"

msgid ""
"Toggle which sections show on the sleep screen. At least one must be visible."
msgstr ""
"Bật/tắt các phần hiển thị trên màn hình chờ. Ít nhất một phần phải hiển thị."

msgid "[ Section Content ]"
msgstr "[ Nội dung phần ]"

msgid "Configure book-specific details."
msgstr "Cấu hình chi tiết riêng của sách."

msgid "Configure chapter-specific details"
msgstr "Cấu hình chi tiết riêng của chương"

msgid "Configure reading goal details"
msgstr "Cấu hình chi tiết mục tiêu đọc sách"

msgid "Battery & time/date section"
msgstr "Phần pin & giờ/ngày"

msgid "Configure battery & time/date details"
msgstr "Cấu hình chi tiết pin & giờ/ngày"

msgid "Configure message-specific details"
msgstr "Cấu hình chi tiết riêng của tin nhắn"
