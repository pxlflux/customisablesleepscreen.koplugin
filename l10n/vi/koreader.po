msgid "Book info"
msgstr "Thông tin sách"

msgid "Chapter info"
msgstr "Thông tin chương"

msgid "Daily info"
msgstr "Thông tin hàng ngày"

msgid "Battery info"
msgstr "Thông tin pin"

msgid "Message info"
msgstr "Thông tin tin nhắn"

msgid "Reorder sections"
msgstr "Sắp xếp lại các phần"

msgid "Section order"
msgstr "Thứ tự phần"

msgid "At least one section must remain visible."
msgstr "Ít nhất một phần phải hiển thị."

msgid "Show book author"
msgstr "Hiển thị tác giả sách"

msgid "Display the author name below the book title."
msgstr "Hiển thị tên tác giả bên dưới tiêu đề sách."

msgid "Show series name"
msgstr "Hiển thị tên bộ sách"

msgid "Display the book's series name and index below the title."
msgstr "Hiển thị tên bộ sách và số thứ tự bên dưới tiêu đề."

msgid "Show book pages (pg x of x)"
msgstr "Hiển thị số trang sách (tr. x / x)"

msgid "Display total page count for the entire book."
msgstr "Hiển thị tổng số trang của toàn bộ cuốn sách."

msgid "Show book time remaining"
msgstr "Hiển thị thời gian đọc còn lại"

msgid "Estimated reading time left to finish the book, based on your average reading speed."
msgstr "Thời gian đọc ước tính còn lại để hoàn thành cuốn sách, dựa trên tốc độ đọc trung bình của bạn."

msgid "Show chapter count (ch x of x)"
msgstr "Hiển thị số chương (ch. x / x)"

msgid "Display current chapter number and total chapters (e.g., 'Chapter 5 of 12')."
msgstr "Hiển thị số chương hiện tại và tổng số chương (ví dụ: 'Chương 5 / 12')."

msgid "Show chapter pages (pg x of x)"
msgstr "Hiển thị số trang chương (tr. x / x)"

msgid "Display the number of pages in the current chapter."
msgstr "Hiển thị số trang trong chương hiện tại."

msgid "Show chapter time remaining"
msgstr "Hiển thị thời gian còn lại của chương"

msgid "Estimated time to finish the current chapter, based on your reading speed."
msgstr "Thời gian ước tính để hoàn thành chương hiện tại, dựa trên tốc độ đọc của bạn."

msgid "Title Line"
msgstr "Dòng tiêu đề"

msgid "Choose what the top line of the daily info section displays."
msgstr "Chọn nội dung hiển thị ở dòng đầu của phần thông tin hàng ngày."

msgid "Pages read today"
msgstr "Số trang đọc hôm nay"

msgid "e.g. '35 pages read today'"
msgstr "vd: '35 trang đã đọc hôm nay'"

msgid "Time read today"
msgstr "Thời gian đọc hôm nay"

msgid "e.g. '42 mins read today'"
msgstr "vd: '42 phút đã đọc hôm nay'"

msgid "Pages and time read today"
msgstr "Số trang và thời gian đọc hôm nay"

msgid "e.g. '35 pgs & 42 mins read today'"
msgstr "vd: '35 tr. & 42 phút đã đọc hôm nay'"

msgid "Goal type"
msgstr "Loại mục tiêu"

msgid "Choose whether your daily goal tracks pages read or time spent reading."
msgstr "Chọn xem mục tiêu hàng ngày theo dõi số trang đọc hay thời gian đọc."

msgid "Page goal"
msgstr "Mục tiêu trang"

msgid "Track daily progress by number of pages read."
msgstr "Theo dõi tiến độ hàng ngày theo số trang đã đọc."

msgid "Time goal"
msgstr "Mục tiêu thời gian"

msgid "Track daily progress by minutes spent reading."
msgstr "Theo dõi tiến độ hàng ngày theo số phút đọc sách."

msgid "Daily page goal"
msgstr "Mục tiêu trang hàng ngày"

msgid "Set how many pages you aim to read each day."
msgstr "Đặt số trang bạn muốn đọc mỗi ngày."

msgid "Daily time goal"
msgstr "Mục tiêu thời gian hàng ngày"

msgid "Set how many minutes you aim to read each day."
msgstr "Đặt số phút bạn muốn đọc mỗi ngày."

msgid "Daily time goal (minutes)"
msgstr "Mục tiêu thời gian hàng ngày (phút)"

msgid "Show current reading streak"
msgstr "Hiển thị chuỗi đọc sách hiện tại"

msgid "Display consecutive days you've met your reading goal."
msgstr "Hiển thị số ngày liên tiếp bạn đạt mục tiêu đọc sách."

msgid "Show weekly progress"
msgstr "Hiển thị tiến độ hàng tuần"

msgid "Days this week you have met your reading goal, shown as completed days out of the current weekday (Monday = 1... Sunday = 7). For example: Thursday with goals met on Monday and Tuesday will show 2/4."
msgstr "Số ngày trong tuần bạn đạt mục tiêu đọc sách, hiển thị dưới dạng ngày hoàn thành trên tổng ngày đến ngày hiện tại trong tuần (Thứ Hai = 1... Chủ Nhật = 7). Ví dụ: Thứ Năm với mục tiêu đạt vào Thứ Hai và Thứ Ba sẽ hiển thị 2/4."

msgid "Show daily goal"
msgstr "Hiển thị mục tiêu hàng ngày"

msgid "Target page mode: e.g. 50 page goal. Target time mode: e.g. 1hr 15min time goal."
msgstr "Chế độ mục tiêu trang: vd. mục tiêu 50 trang. Chế độ mục tiêu thời gian: vd. mục tiêu 1 giờ 15 phút."

msgid "Show current time/date on separate line"
msgstr "Hiển thị giờ/ngày hiện tại trên dòng riêng"

msgid "Display time/date on its own line below battery percentage instead of inline."
msgstr "Hiển thị giờ/ngày trên dòng riêng bên dưới phần trăm pin thay vì hiển thị cùng dòng."

msgid "Enable 'Show battery time remaining' to use this option"
msgstr "Bật 'Hiển thị thời gian pin còn lại' để sử dụng tùy chọn này"

msgid "Show date instead of time"
msgstr "Hiển thị ngày thay vì giờ"

msgid "Display current date (e.g. '29th Jan') instead of time in battery section"
msgstr "Hiển thị ngày hiện tại (ví dụ: '29 tháng 1') thay vì giờ trong phần pin"

msgid "Show battery consumption rate"
msgstr "Hiển thị tốc độ tiêu hao pin"

msgid "Display battery drain percentage per hour based on recent usage or manual input (see advanced menu)"
msgstr "Hiển thị phần trăm tiêu hao pin mỗi giờ dựa trên mức sử dụng gần đây hoặc nhập thủ công (xem menu nâng cao)"

msgid "Show battery time remaining"
msgstr "Hiển thị thời gian pin còn lại"

msgid "Estimated hours and minutes until battery is depleted, based on current drain rate."
msgstr "Số giờ và phút ước tính cho đến khi hết pin, dựa trên tốc độ tiêu hao hiện tại."

msgid "Custom message"
msgstr "Tin nhắn tùy chỉnh"

msgid "Use a separate custom message just for Customisable Sleep Screen"
msgstr "Dùng tin nhắn tùy chỉnh riêng chỉ cho màn hình chờ tùy chỉnh"

