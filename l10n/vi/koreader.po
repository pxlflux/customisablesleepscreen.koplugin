msgid "Dark mode"
msgstr "Chế độ tối"

msgid ""
"Inverts the colour scheme. Text becomes white and backgrounds becomes black. "
"Useful for reading in low-light conditions. Can be combined with monochrome "
"mode."
msgstr ""
"Đảo ngược bảng màu. Văn bản chuyển thành màu trắng, nền chuyển thành màu đen. "
"Hữu ích khi đọc trong điều kiện ánh sáng yếu. Có thể kết hợp với chế độ đơn sắc."

msgid "Monochrome mode"
msgstr "Chế độ đơn sắc"

msgid ""
"Suitable for B&W e-readers. Assigns one colour to all sections using "
"monochrome light or monochrome dark hex values. Overwrites individual "
"assigned section colours. Can be combined with dark mode."
msgstr ""
"Phù hợp với máy đọc sách đen trắng. Gán một màu cho tất cả các phần bằng cách "
"sử dụng giá trị hex đơn sắc sáng hoặc đơn sắc tối. Ghi đè màu phần riêng lẻ. "
"Có thể kết hợp với chế độ tối."

msgid "Enable section gaps"
msgstr "Bật khoảng cách giữa các phần"

msgid ""
"Add transparent gaps between sections to make each appear as a separate box"
msgstr ""
"Thêm khoảng cách trong suốt giữa các phần để mỗi phần "
"hiển thị như một hộp riêng biệt"

msgid "Section gap size"
msgstr "Kích thước khoảng cách phần"

msgid "Spacing between sections when gaps are enabled."
msgstr "Khoảng cách giữa các phần khi bật khoảng cách."

msgid "Section gap size (pixels)"
msgstr "Kích thước khoảng cách phần (pixel)"

msgid "Position"
msgstr "Vị trí"

msgid "Screen location where the information box appears."
msgstr "Vị trí trên màn hình nơi hộp thông tin hiển thị."

msgid "Width"
msgstr "Chiều rộng"

msgid ""
"Horizontal width of the information box as a percentage of screen width."
msgstr ""
"Chiều rộng ngang của hộp thông tin theo phần trăm chiều rộng màn hình."

msgid "Opacity"
msgstr "Độ mờ"

msgid "Transparency of the information box."
msgstr "Độ trong suốt của hộp thông tin."

msgid "Border size"
msgstr "Kích thước viền"

msgid "Thickness of the primary border around sections."
msgstr "Độ dày của viền chính quanh các phần."

msgid "Border trim size"
msgstr "Kích thước viền trang trí"

msgid "Secondary decorative border surrounding the primary border."
msgstr "Viền trang trí phụ bao quanh viền chính."

msgid "Internal padding"
msgstr "Đệm bên trong"

msgid "Space between section borders and their content."
msgstr "Khoảng cách giữa viền phần và nội dung của chúng."

msgid "Icon to text gap"
msgstr "Khoảng cách biểu tượng - văn bản"

msgid "Horizontal spacing between section icons and their accompanying text."
msgstr "Khoảng cách ngang giữa biểu tượng phần và văn bản đi kèm."

msgid "Y-axis margin (top/bottom left/right pos)"
msgstr "Lề trục Y (vị trí trên/dưới trái/phải)"

msgid ""
"Vertical offset from the top or bottom edge when positioned at the top "
"centre, bottom centre, top left, bottom left, top right or bottom right."
msgstr ""
"Độ lệch dọc từ cạnh trên hoặc dưới khi đặt ở trên giữa, dưới giữa, "
"trên trái, dưới trái, trên phải hoặc dưới phải."

msgid "No icon sets found in customisablesleepscreen.koplugin/icons/"
msgstr "Không tìm thấy bộ biểu tượng trong customisablesleepscreen.koplugin/icons/"

msgid "Off"
msgstr "Tắt"

msgid "Overlay colour"
msgstr "Màu phủ"

msgid "Background overlay colour"
msgstr "Màu phủ nền"

msgid "Colours (progress bars)"
msgstr "Màu sắc (thanh tiến trình)"

msgid "Set the progress bar colours for each section."
msgstr "Đặt màu thanh tiến trình cho từng phần."

msgid "Colours (modes)"
msgstr "Màu sắc (chế độ)"

msgid ""
"Configure colours for monochrome mode, infobox background, and text. "
"Light and dark correspond to the current dark mode setting. "
"Monochrome replaces all colours with that single chosen color."
msgstr ""
"Cấu hình màu sắc cho chế độ đơn sắc, nền hộp thông tin và văn bản. "
"Sáng và tối tương ứng với cài đặt chế độ tối hiện tại. "
"Đơn sắc thay thế tất cả màu sắc bằng một màu đã chọn."

msgid "Use saved colours for icon fill"
msgstr "Dùng màu đã lưu để tô biểu tượng"

msgid ""
"When enabled, icons will match the colour of their section's progress bar."
msgstr ""
"Khi bật, biểu tượng sẽ khớp màu với thanh tiến trình của phần đó."

msgid "Book section"
msgstr "Phần sách"

