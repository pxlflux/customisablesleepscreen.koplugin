msgstr "Thay đổi tiêu đề tin nhắn tùy chỉnh"

msgid "Edit custom message"
msgstr "Chỉnh sửa tin nhắn tùy chỉnh"

msgid "Write your custom message text. Only active when 'Custom message' is selected. Supports variables: %d, %y, %t, %b, %r."
msgstr "Nhập văn bản tin nhắn tùy chỉnh. Chỉ hoạt động khi chọn 'Tin nhắn tùy chỉnh'. Hỗ trợ biến: %d, %y, %t, %b, %r."

msgid "Custom Customisable Sleep Screen message"
msgstr "Tin nhắn tùy chỉnh màn hình chờ tùy chỉnh"

msgid "Book highlight maximum length"
msgstr "Độ dài tối đa đánh dấu sách"

msgid "Maximum characters to display for highlights (0 = no limit)."
msgstr "Số ký tự tối đa để hiển thị đánh dấu (0 = không giới hạn)."

msgid "Maximum highlight length"
msgstr "Độ dài đánh dấu tối đa"

msgid "Set to 0 for no limit"
msgstr "Đặt thành 0 để không giới hạn"

msgid "Add quotation marks to highlights"
msgstr "Thêm dấu ngoặc kép vào đánh dấu"

msgid "Wraps all highlights in curly double quotes, removing any pre-existing quotation marks."
msgstr "Bọc tất cả đánh dấu trong dấu ngoặc kép cong, xóa bỏ các dấu ngoặc kép có sẵn."

msgid "Show highlight location"
msgstr "Hiển thị vị trí đánh dấu"

msgid "Display the chapter title and page number where the highlight is found, shown below the highlight text."
msgstr "Hiển thị tiêu đề chương và số trang nơi đánh dấu được tìm thấy, hiển thị bên dưới văn bản đánh dấu."

msgid "Show quote attribution"
msgstr "Hiển thị nguồn trích dẫn"

msgid "Display the author and book name below the quote, if provided in custom_quotes.lua."
msgstr "Hiển thị tác giả và tên sách bên dưới trích dẫn, nếu được cung cấp trong custom_quotes.lua."

msgid "Show titles (top line)"
msgstr "Hiển thị tiêu đề (dòng trên)"

msgid "Display the main heading text in each section. At least one of titles or subtitles must be visible."
msgstr "Hiển thị văn bản tiêu đề chính trong mỗi phần. Ít nhất một trong tiêu đề hoặc phụ đề phải hiển thị."

msgid "Cannot hide both titles and subtitles. At least one must be visible."
msgstr "Không thể ẩn cả tiêu đề và phụ đề. Ít nhất một cái phải hiển thị."

msgid "Show subtitles (bottom lines)"
msgstr "Hiển thị phụ đề (dòng dưới)"

msgid "Display information below main heading text in each section. At least one of titles or subtitles must be visible."
msgstr "Hiển thị thông tin bên dưới văn bản tiêu đề chính trong mỗi phần. Ít nhất một trong tiêu đề hoặc phụ đề phải hiển thị."

msgid "Displayed sections"
msgstr "Các phần hiển thị"

msgid "Toggle which sections show on the sleep screen. At least one must be visible."
msgstr "Bật/tắt các phần hiển thị trên màn hình chờ. Ít nhất một phần phải hiển thị."

