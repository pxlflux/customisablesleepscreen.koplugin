msgstr "Chọn từ các kiểu biểu tượng khác nhau."

msgid "Icon size"
msgstr "Kích thước biểu tượng"

msgid "Size of section icons."
msgstr "Kích thước biểu tượng phần."

msgid "Progress bar height"
msgstr "Chiều cao thanh tiến trình"

msgid "Thickness of the horizontal progress bars shown in each section."
msgstr "Độ dày của các thanh tiến trình ngang hiển thị trong mỗi phần."

msgid "Show icons"
msgstr "Hiển thị biểu tượng"

msgid "Display decorative icons at the start of each section."
msgstr "Hiển thị biểu tượng trang trí ở đầu mỗi phần."

msgid "Show progress bars"
msgstr "Hiển thị thanh tiến trình"

msgid "Display horizontal progress bars showing completion percentage."
msgstr "Hiển thị các thanh tiến trình ngang cho thấy phần trăm hoàn thành."

msgid "Show decorative bar on message section"
msgstr "Hiển thị thanh trang trí trong phần tin nhắn"

msgid ""
"Displays a purely decorative progress bar under the message section, "
"matching the message section colour and the progress bars in other sections."
msgstr "Hiển thị thanh tiến trình thuần trang trí bên dưới phần thông điệp, khớp với màu của phần thông điệp và các thanh tiến trình ở các phần khác."

msgid "Title font face"
msgstr "Phông chữ tiêu đề"

msgid "Choose the font face for the main heading text in each section"
msgstr "Chọn phông chữ cho văn bản tiêu đề chính trong mỗi phần"

msgid "Title font size"
msgstr "Cỡ chữ tiêu đề"

msgid "Choose the font size for the main heading text in each section"
msgstr "Chọn cỡ chữ cho văn bản tiêu đề chính trong mỗi phần"

msgid "Subtitle font face"
msgstr "Phông chữ phụ đề"

msgid "Choose the font face for the information below the main heading text."
msgstr "Chọn phông chữ cho thông tin bên dưới văn bản tiêu đề chính."

msgid "Subtitle font size"
msgstr "Cỡ chữ phụ đề"

msgid "Choose the font size for the information below the main heading text."
msgstr "Chọn cỡ chữ cho thông tin bên dưới văn bản tiêu đề chính."

msgid "Text alignment"
msgstr "Căn chỉnh văn bản"

msgid "Horizontal alignment of all text within sections."
msgstr "Căn chỉnh ngang của tất cả văn bản trong các phần."

msgid "Left"
msgstr "Trái"

msgid "Right"
msgstr "Phải"

msgid "Book multiline titles"
msgstr "Tiêu đề sách nhiều dòng"

msgid ""
"If deselected book titles will be truncated to a single line with an ellipsis"
msgstr ""
"Nếu bỏ chọn, tiêu đề sách sẽ bị cắt thành một dòng với dấu chấm lửng"

msgid "Chapter multiline titles"
msgstr "Tiêu đề chương nhiều dòng"

msgid ""
"If deselected chapter titles will be truncated to a single line with an "
"ellipsis"
msgstr ""
"Nếu bỏ chọn, tiêu đề chương sẽ bị cắt thành một dòng với dấu chấm lửng"

msgid "Clean chapter titles"
msgstr "Làm sạch tiêu đề chương"

msgid ""
"Removes structural prefixes like 'Chapter 5:' or 'Part II' from chapter "
"titles and normalises capitalisation. Only works correctly with English "
"chapter titles - disable for non-English books."
msgstr ""
"Xóa các tiền tố cấu trúc như 'Chapter 5:' hoặc 'Part II' khỏi tiêu đề chương "
"và chuẩn hóa chữ hoa. Chỉ hoạt động chính xác với tiêu đề chương tiếng Anh — "
"tắt đi cho sách không phải tiếng Anh."

msgid "Make book title bold"
msgstr "In đậm tiêu đề sách"

msgid "Display the book title in bold font weight for extra emphasis."
msgstr "Hiển thị tiêu đề sách bằng phông chữ đậm để nhấn mạnh thêm."

msgid "No background"
msgstr "Không có nền"

msgid "Book cover"
msgstr "Bìa sách"

msgid "Solid colour"
msgstr "Màu đơn sắc"

msgid "Random image from folder"
msgstr "Hình ảnh ngẫu nhiên từ thư mục"

msgid "Stretch book cover to fill"
msgstr "Kéo giãn bìa sách để lấp đầy"

msgid ""
"When disabled, book cover will be scaled to fit within the screen while "
"preserving aspect ratio."
msgstr ""
"Khi tắt, bìa sách sẽ được thu nhỏ/phóng to để vừa với màn hình "
"trong khi giữ nguyên tỷ lệ khung hình."

msgid "Cover fill colour"
msgstr "Màu nền bìa sách"

msgid "Background colour for non-stretched covers."
msgstr "Màu nền cho bìa không kéo giãn."

msgid "Black"
msgstr "Đen"

msgid "White"
msgstr "Trắng"

msgid "Solid background colour"
msgstr "Màu nền đơn sắc"

msgid "Pick background colour"
msgstr "Chọn màu nền"

msgid "Background folder path"
msgstr "Đường dẫn thư mục nền"

msgid "No images found in the selected folder. No background will be shown."
msgstr "Không tìm thấy hình ảnh trong thư mục đã chọn. Sẽ không hiển thị nền."

msgid "Background type"
msgstr "Loại nền"

msgid "Background overlay"
msgstr "Lớp phủ nền"

msgid "Add a colour layer over the background to reduce contrast."
msgstr "Thêm lớp màu lên nền để giảm độ tương phản."

msgid "Reset layout & spacing settings to default"
msgstr "Đặt lại cài đặt bố cục & khoảng cách"

msgid "Are you sure you want to reset layout & spacing settings?"
msgstr "Bạn có chắc muốn đặt lại cài đặt bố cục & khoảng cách không?"

msgid "Layout & spacing settings reset to defaults"
msgstr "Đã đặt lại cài đặt bố cục & khoảng cách"

msgid "Reset contents settings to default"
msgstr "Đặt lại cài đặt nội dung"

msgid "Are you sure you want to reset contents settings?"
msgstr "Bạn có chắc muốn đặt lại cài đặt nội dung không?"

msgid "Contents settings reset to defaults"
msgstr "Đã đặt lại cài đặt nội dung"

msgid "Reset colours, icons & bars settings to default"
msgstr "Đặt lại cài đặt màu sắc, biểu tượng & thanh"

msgid "Are you sure you want to reset colours, icons & bars settings?"
msgstr "Bạn có chắc muốn đặt lại cài đặt màu sắc, biểu tượng & thanh không?"

msgid "Colours, icons & bars settings reset to defaults"
msgstr "Đã đặt lại cài đặt màu sắc, biểu tượng & thanh"

msgid "Reset fonts & text settings to default"
msgstr "Đặt lại cài đặt phông chữ & văn bản"

msgid "Are you sure you want to reset fonts & text settings?"
msgstr "Bạn có chắc muốn đặt lại cài đặt phông chữ & văn bản không?"

msgid "Fonts & text settings reset to defaults"
msgstr "Đã đặt lại cài đặt phông chữ & văn bản"

msgid "Reset background settings to default"
msgstr "Đặt lại cài đặt nền"

msgid "Are you sure you want to reset background settings?"
msgstr "Bạn có chắc muốn đặt lại cài đặt nền không?"

msgid "Background settings reset to defaults"
msgstr "Đã đặt lại cài đặt nền"

msgid "Reset the settings in this part of the menu to their defaults."
msgstr "Đặt lại cài đặt trong phần menu này về mặc định."

msgid "factory defaults"
msgstr "cài đặt mặc định của nhà máy"

#, lua-format
msgid "Values will be restored from: %s"
msgstr "Các giá trị sẽ được khôi phục từ: %s"

