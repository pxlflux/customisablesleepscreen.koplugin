msgstr "Exibe barras de progresso horizontais mostrando o percentual de conclusão."

msgid "Show decorative bar on message section"
msgstr "Mostrar barra decorativa na seção de mensagens"

msgid ""
"Displays a purely decorative progress bar under the message section, "
"matching the message section colour and the progress bars in other sections."
msgstr "Exibe uma barra de progresso puramente decorativa abaixo da seção de mensagens, combinando com a cor da seção de mensagens e as barras de progresso das outras seções."

msgid "Title font face"
msgstr "Fonte do título"

msgid "Choose the font face for the main heading text in each section"
msgstr "Escolhe a fonte para o texto do cabeçalho principal em cada seção"

msgid "Title font size"
msgstr "Tamanho da fonte do título"

msgid "Choose the font size for the main heading text in each section"
msgstr "Escolhe o tamanho da fonte para o texto do cabeçalho principal em cada seção"

msgid "Subtitle font face"
msgstr "Fonte do subtítulo"

msgid "Choose the font face for the information below the main heading text."
msgstr "Escolhe a fonte para as informações abaixo do texto do cabeçalho principal."

msgid "Subtitle font size"
msgstr "Tamanho da fonte do subtítulo"

msgid "Choose the font size for the information below the main heading text."
msgstr "Escolhe o tamanho da fonte para as informações abaixo do texto do cabeçalho principal."

