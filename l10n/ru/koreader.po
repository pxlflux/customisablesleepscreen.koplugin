msgstr "Раздел батареи (Средний)"

msgid "Battery section (Low)"
msgstr "Раздел батареи (Низкий)"

msgid "Battery section (Charging)"
msgstr "Раздел батареи (Зарядка)"

msgid "Colours (modes)"
msgstr "Цвета (режимы)"

msgid "Configure colours for monochrome mode, infobox background, and text. Light and dark correspond to the current dark mode setting. Monochrome replaces all colours with that single chosen color."
msgstr "Настройка цветов для монохромного режима, фона информационного блока и текста. Светлый и тёмный соответствуют текущей настройке тёмного режима. Монохромный заменяет все цвета одним выбранным цветом."

msgid "Monochrome mode (light)"
msgstr "Монохромный режим (светлый)"

msgid "Monochrome mode (dark)"
msgstr "Монохромный режим (тёмный)"

