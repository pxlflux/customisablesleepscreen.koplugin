msgid "Battery section (Low)"
msgstr "Akkubereich (Niedrig)"

msgid "Battery section (Charging)"
msgstr "Akkubereich (Lädt)"

msgid "Colours (modes)"
msgstr "Farben (Modi)"

msgid ""
"Configure colours for monochrome mode, infobox background, and text. Light "
"and dark correspond to the current dark mode setting. Monochrome replaces "
"all colours with that single chosen color."
msgstr ""
"Farben für den Monochrom-Modus, den Infobox-Hintergrund und Text "
"konfigurieren. Hell und Dunkel entsprechen der aktuellen Dunkel-Modus-"
"Einstellung. Monochrom ersetzt alle Farben durch die gewählte Einzelfarbe."

msgid "Monochrome mode (light)"
msgstr "Monochrommodus (Hell)"

msgid "Monochrome mode (dark)"
msgstr "Monochrommodus (Dunkel)"

